    "@types/uuid": "^10.0.0",
    "jest": "^30.3.0",
    "prisma": "^6.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
