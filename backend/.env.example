PORT=3001
NODE_ENV=development

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ktx_db?schema=public"

REDIS_URL="redis://localhost:6379"

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Chatbot LLM (OpenRouter — default DeepSeek V3.2: https://openrouter.ai/deepseek/deepseek-v3.2 )
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=deepseek/deepseek-v3.2
# Faster/cheaper model for intent classification, general chat, and DB summaries (see https://openrouter.ai/qwen/qwen3.5-9b/api )
OPENROUTER_LIGHT_MODEL=qwen/qwen3.5-9b
# RAG embeddings use the same OPENROUTER_API_KEY (POST /api/v1/embeddings). Pick a model from OpenRouter Embeddings docs.
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# Optional: truncate dimensions for supported models, and align hash-fallback vector size (default 1536)
# OPENROUTER_EMBEDDING_DIMENSIONS=1536
# Optional overrides:
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=http://localhost:3000
# OPENROUTER_APP_TITLE=Quan Ly KTX
# MAX_TOKENS=4096
# TEMPERATURE=0.7
# Policy/RAG answer cap (default 2048)
# MAX_TOKENS_POLICY=2048
# Short general chat (default 512)
# MAX_TOKENS_GENERAL=512
# Summarize structured DB results (default 1024)
# MAX_TOKENS_DATA_SUMMARY=1024
# Intent classifier (small completion)
# INTENT_CLASSIFY_MAX_TOKENS=24
# INTENT_CLASSIFY_TEMPERATURE=0
# OPENROUTER_INTENT_MODEL=openai/gpt-4o-mini
# If classifier output is invalid, use POLICY or GENERAL
# CHAT_INTENT_FALLBACK=GENERAL
# Optional: how much of the user question is sent in LLM prompts (default 8000). DB still stores full message.
# CHAT_PROMPT_QUESTION_MAX_CHARS=8000
# Optional: JSON size cap in data-summary prompts (default 24000)
# CHAT_DATA_JSON_PROMPT_MAX_CHARS=24000
# DB intents (hóa đơn, lịch, phòng): default = format Markdown in-app (fast). Set to 1 to use LLM summary again.
# CHAT_DATA_USE_LLM_SUMMARY=0
# Agentic RAG (default): LLM chọn tool search_knowledge (Chroma) + đọc PostgreSQL qua tool có RBAC. Đặt =1 để dùng lại luồng heuristic + RAG cũ.
# CHAT_USE_LEGACY_PIPELINE=0
# Số vòng LLM tối đa (mỗi vòng có thể gọi tool), tối thiểu 2 tối đa 8 (mặc định 5).
# CHAT_MAX_TOOL_ROUNDS=5
# Model cho agent (mặc định = OPENROUTER_MODEL).
# CHAT_AGENT_MODEL=
# Max tokens mỗi vòng gọi tool (trước câu trả lời cuối).
# CHAT_AGENT_TOOL_MAX_TOKENS=1024
# Skip extra LLM call when heuristic already picks PAYMENT_STATUS / SCHEDULE / ROOM_INFO (default on). Set to 0 to always classify via LLM.
# CHAT_INTENT_SKIP_LLM_FOR_DATA=0
# Optional: override Vietnamese message when the model returns empty / off-scope (default built-in).
# CHAT_ASSISTANT_EMPTY_FALLBACK_VI=

# ChromaDB HTTP API (required for RAG). chromadb@3 has no embedded ./chroma_db path.
# Docker Compose maps host 8001 → container 8000 (tránh xung đột với WordPress/app dùng :8000).
# Run: docker compose up -d chromadb   →  backend chạy ngoài Docker: http://localhost:8001
CHROMADB_URL=http://localhost:8001
# Optional override of collection name (default ktx_knowledge_base)
# CHROMADB_COLLECTION=ktx_knowledge_base
# RAG vẫn dùng OpenRouter (createEmbedding). Gói @chroma-core/default-embed trong package.json chỉ để client chromadb@3 không cảnh báo khi server trả cấu hình embedding "default".

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

VNPAY_TMN_CODE=your-tmncode
VNPAY_SECRET_KEY=your-secret-key
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3001/api/v1/invoices/payment/callback

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

FRONTEND_URL=http://localhost:3000
# Optional: extra CORS origins (comma-separated). Docker Compose adds http://frontend:3000 by default.
# FRONTEND_ORIGINS=http://frontend:3000,http://127.0.0.1:3000
